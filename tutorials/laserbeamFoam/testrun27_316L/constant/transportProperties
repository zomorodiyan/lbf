FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Interface tracking method: isoAdvector or MULES
interfaceTrackingScheme isoAdvector;

phases          (metal gas);

metal
{
    transportModel  Newtonian;
nu              5e-07;

rho             8000;

	Tsolidus 1658;
	Tliquidus 1723;
    LatentHeat 2.7e5;
    beta    5.0e-6;
    poly_kappa   (11.5 0.00307 0 0 0 0 0 0);  // linear: ~16.4 W/(m.K) at 300K, ~25 W/(m.K) at 1800K
    poly_cp   (500 0.0 0 0 0 0 0 0);
    elec_resistivity	1.6384e-7;  // A0=10% at normal incidence (Drude-Fresnel, lambda=1.064um)
}

gas
{
    transportModel  Newtonian;

nu              1.48e-05;

rho             1;

    poly_kappa   (0.04 0 0 0 0 0 0 0);
    poly_cp   (520 0.0 0 0 0 0 0 0);
    
    Tsolidus    1.0;
    Tliquidus   10.0;
    LatentHeat  1;
    beta    4.0e-5;
}



sigma            2.3310;   // Morohoshi 2013 at T=1873K, pure 316L +25% — CSF term (constant)

// Full Morohoshi σ(T) polynomial for pure 316L (eta=0, wC=0.030, wO=0.001)
// σ in N/m, T in K.  Used only to compute dσ/dT per cell for Marangoni term.
// T* (dσ/dT=0) ≈ 1787 K — just 64 K above liquidus, so nonlinearity is mild.
// Below ~1787 K: dσ/dT > 0 (thin inward zone near solidification front)
// Above ~1787 K: dσ/dT < 0 (outward — dominant behaviour over most of melt pool)
poly_sigma (-8.937188e+01  2.169045e-01 -2.130205e-04  1.109408e-07 -3.237209e-11  5.016921e-15 -3.225644e-19  0.000000e+00);
p0	1e5;
Tvap	3068;
Mm	0.05;
LatentHeatVap 7.45e6;
emS                     0.4;
emL                     0.1;
TRef                    TRef [0 0 0 1 0 0 0]   300;
// ************************************************************************* //
